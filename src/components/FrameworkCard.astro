---
import StatusBadge from './StatusBadge.astro';

interface Props {
  name: string;
  status: 'certified' | 'in-progress' | 'planned';
  description?: string | undefined;
  certifiedDate?: string | null | undefined;
  auditBody?: string | null | undefined;
  reportAvailable?: boolean | undefined;
  securityEmail?: string | undefined;
}

const {
  name,
  status,
  description,
  certifiedDate,
  auditBody,
  reportAvailable = false,
  securityEmail,
} = Astro.props;

const reportSubject = encodeURIComponent(`${name} Report Request`);
const reportBody = encodeURIComponent(
  `Hi,\n\nI'd like to request a copy of your ${name} report.\n\nThanks`,
);
---

<div
  class="rounded-lg border border-gray-200 bg-white/60 p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800/40"
>
  <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1">
    <h3
      class="text-lg font-medium text-gray-900 dark:text-gray-100"
      style="font-family: var(--font-heading)"
    >
      {name}
    </h3>
    <StatusBadge status={status} />
  </div>
  {
    description && (
      <p class="mt-2 leading-relaxed text-gray-500 dark:text-gray-400">{description}</p>
    )
  }
  {
    certifiedDate && (
      <p class="mt-2 text-sm text-gray-400 dark:text-gray-500">
        Certified since {certifiedDate}
        {auditBody ? ` · ${auditBody}` : ''}
      </p>
    )
  }
  {
    reportAvailable && securityEmail && (
      <a
        href={`mailto:${securityEmail}?subject=${reportSubject}&body=${reportBody}`}
        class="mt-3 inline-block text-sm font-medium transition-colors hover:underline"
        style="color: var(--color-primary-500)"
      >
        Request Report &rarr;
      </a>
    )
  }
</div>
