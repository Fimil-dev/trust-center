---
interface Subprocessor {
  name: string;
  purpose: string;
  location: string;
  dpaUrl: string | null;
}

interface Props {
  subprocessors: Subprocessor[];
  privacyEmail?: string | undefined;
  lastUpdated?: string | undefined;
}

const { subprocessors, privacyEmail, lastUpdated } = Astro.props;

const sorted = [...subprocessors].sort((a, b) => a.name.localeCompare(b.name));
---

<div>
  {/* Desktop table */}
  <div class="hidden sm:block">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-gray-200 dark:border-gray-800">
          <th
            class="pb-3 text-left text-xs font-medium tracking-wider text-gray-400 uppercase dark:text-gray-500"
            style="font-family: var(--font-heading)"
          >
            Vendor
          </th>
          <th
            class="pb-3 text-left text-xs font-medium tracking-wider text-gray-400 uppercase dark:text-gray-500"
            style="font-family: var(--font-heading)"
          >
            Purpose
          </th>
          <th
            class="pb-3 text-left text-xs font-medium tracking-wider text-gray-400 uppercase dark:text-gray-500"
            style="font-family: var(--font-heading)"
          >
            Location
          </th>
          <th
            class="pb-3 text-right text-xs font-medium tracking-wider text-gray-400 uppercase dark:text-gray-500"
            style="font-family: var(--font-heading)"
          >
            DPA
          </th>
        </tr>
      </thead>
      <tbody>
        {
          sorted.map((sp) => (
            <tr>
              <td class="py-4 font-medium text-gray-900 dark:text-gray-100">{sp.name}</td>
              <td class="py-4 text-gray-500 dark:text-gray-400">{sp.purpose}</td>
              <td class="py-4 text-gray-500 dark:text-gray-400">{sp.location}</td>
              <td class="py-4 text-right">
                {sp.dpaUrl ? (
                  <a
                    href={sp.dpaUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-gray-400 transition-colors hover:text-gray-700 dark:hover:text-gray-200"
                    aria-label={`Data Processing Agreement for ${sp.name}`}
                  >
                    &rarr;
                  </a>
                ) : (
                  <span class="text-gray-200 dark:text-gray-700">&mdash;</span>
                )}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  {/* Mobile stacked */}
  <div class="space-y-6 sm:hidden">
    {
      sorted.map((sp) => (
        <div>
          <div class="flex items-baseline justify-between gap-2">
            <h4 class="font-medium text-gray-900 dark:text-gray-100">{sp.name}</h4>
            {sp.dpaUrl && (
              <a
                href={sp.dpaUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-xs text-gray-400 hover:underline"
                aria-label={`Data Processing Agreement for ${sp.name}`}
              >
                DPA &rarr;
              </a>
            )}
          </div>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">{sp.purpose}</p>
          <p class="mt-0.5 text-xs text-gray-400 dark:text-gray-500">{sp.location}</p>
        </div>
      ))
    }
  </div>

  <div
    class="mt-8 flex flex-wrap items-baseline gap-x-6 gap-y-2 text-xs text-gray-400 dark:text-gray-500"
  >
    {lastUpdated && <p>Last updated: {lastUpdated}</p>}
    {
      privacyEmail && (
        <p>
          Questions about subprocessors?{' '}
          <a
            href={`mailto:${privacyEmail}`}
            class="underline transition-colors hover:text-gray-600 dark:hover:text-gray-300"
          >
            {privacyEmail}
          </a>
        </p>
      )
    }
  </div>
</div>
