---
interface Props {
  heading: string;
  description?: string;
  ctaLabel: string;
  ctaHref: string;
  questionnaireUrl?: string | null;
  prefilledQuestionnaireUrl?: string | null;
}

const { heading, description, ctaLabel, ctaHref, questionnaireUrl, prefilledQuestionnaireUrl } =
  Astro.props;
---

<div class="py-20 sm:py-28">
  <h2
    class="text-2xl font-semibold text-gray-900 sm:text-3xl dark:text-gray-100"
    style="font-family: var(--font-heading)"
  >
    {heading}
  </h2>
  {
    description && (
      <p class="mt-4 max-w-lg leading-relaxed text-gray-500 dark:text-gray-400">{description}</p>
    )
  }
  <div class="mt-8 flex flex-wrap items-center gap-6">
    <a
      href={ctaHref}
      class="text-sm font-medium transition-colors hover:underline"
      style="color: var(--color-primary-500)"
    >
      {ctaLabel} &rarr;
    </a>
    {
      questionnaireUrl && (
        <a
          href={questionnaireUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-gray-500 transition-colors hover:text-gray-700 hover:underline dark:text-gray-400 dark:hover:text-gray-200"
        >
          Submit Questionnaire &rarr;
        </a>
      )
    }
    {
      prefilledQuestionnaireUrl && (
        <a
          href={prefilledQuestionnaireUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-gray-500 transition-colors hover:text-gray-700 hover:underline dark:text-gray-400 dark:hover:text-gray-200"
        >
          Download Pre-filled CAIQ &rarr;
        </a>
      )
    }
  </div>
</div>
