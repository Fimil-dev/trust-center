---
interface Props {
  name: string;
  slug: string;
  description: string;
  questionCount: number;
  sectionCount: number;
  version?: string | undefined;
}

const { name, slug, description, questionCount, sectionCount, version } = Astro.props;
---

<a
  href={`/questionnaires/${slug}/`}
  class="group block rounded-lg border border-gray-200 bg-white/60 p-6 shadow-sm transition-colors hover:border-gray-300 dark:border-gray-700 dark:bg-gray-800/40 dark:hover:border-gray-600"
>
  <div class="flex items-baseline justify-between gap-2">
    <h3
      class="text-base font-medium text-gray-900 dark:text-gray-100"
      style="font-family: var(--font-heading)"
    >
      {name}
    </h3>
    {
      version && (
        <span
          class="text-xs text-gray-400 dark:text-gray-500"
          style="font-family: var(--font-heading)"
        >
          v{version}
        </span>
      )
    }
  </div>
  <p class="mt-1 text-xs text-gray-400 tabular-nums dark:text-gray-500">
    {questionCount} questions &middot; {sectionCount} sections
  </p>
  <p class="mt-3 text-sm leading-relaxed text-gray-500 dark:text-gray-400">
    {description}
  </p>
  <span
    class="mt-4 inline-block text-sm font-medium transition-colors group-hover:underline"
    style="color: var(--color-primary-500)"
  >
    Browse Questionnaire &rarr;
  </span>
</a>
