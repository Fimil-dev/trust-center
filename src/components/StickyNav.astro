---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  companyName: string;
  logo?: string;
}

const { companyName, logo } = Astro.props;
---

<nav
  class="sticky top-0 z-50 border-b border-gray-200 bg-white dark:border-gray-800 dark:bg-gray-950"
>
  <div class="mx-auto flex h-12 max-w-5xl items-center justify-between px-6">
    <a href="/" class="flex items-center gap-2.5">
      {logo && <img src={logo} alt={companyName} class="h-5 w-auto dark:invert" />}
      <span
        class="text-xs font-medium tracking-wider text-gray-900 uppercase dark:text-gray-100"
        style="font-family: var(--font-heading)"
      >
        {companyName}
      </span>
    </a>
    <ThemeToggle />
  </div>
</nav>
