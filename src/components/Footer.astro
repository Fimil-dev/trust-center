---
interface Props {
  companyName: string;
  website?: string | undefined;
  lastReviewed?: string | undefined;
}

const { companyName, website, lastReviewed } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="border-t border-gray-200 py-8 dark:border-gray-800">
  <div class="mx-auto flex max-w-5xl items-baseline justify-between px-6">
    <p class="text-xs text-gray-400 dark:text-gray-500" style="font-family: var(--font-heading)">
      &copy; {year}
      {
        website ? (
          <a href={website} class="hover:underline">
            {companyName}
          </a>
        ) : (
          companyName
        )
      }
    </p>
    {
      lastReviewed && (
        <p
          class="text-xs text-gray-400 dark:text-gray-500"
          style="font-family: var(--font-heading)"
        >
          Last reviewed: {lastReviewed}
        </p>
      )
    }
  </div>
</footer>
